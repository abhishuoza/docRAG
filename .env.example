# LLM Backend: "openai", "anthropic", or "local"
DOCRAG_LLM_BACKEND=openai

# API Keys (set the one matching your backend)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Model names (defaults shown)
DOCRAG_OPENAI_MODEL=gpt-4o-mini
DOCRAG_ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
DOCRAG_LOCAL_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# Embedding model
DOCRAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Text splitting
DOCRAG_CHUNK_SIZE=1000
DOCRAG_CHUNK_OVERLAP=200

# ChromaDB
DOCRAG_CHROMA_DIR=./data/chroma
DOCRAG_CHROMA_COLLECTION=docrag_docs

# Cache
DOCRAG_CACHE_DIR=./data/cache
DOCRAG_CACHE_TTL_HOURS=24

# API server
DOCRAG_API_HOST=0.0.0.0
DOCRAG_API_PORT=8000